# Server Port
PORT=3000

# Azure AD (Microsoft 365) Settings
# Replace with your Azure AD App Registration values
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# SharePoint Integration Settings
# Replace with your SharePoint site details
SHAREPOINT_HOST=your-sharepoint-host.sharepoint.com
SHAREPOINT_SITE=YourSiteName
SHAREPOINT_LIST_NAME=YourListName
SHAREPOINT_LIST_ID=your-sharepoint-list-id

# Vercel Token (optional for local testing)
# VERCEL_TOKEN=your-vercel-token
